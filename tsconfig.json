{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@pengawas/shared": ["packages/shared/src/index.ts"],
      "@pengawas/shared/*": ["packages/shared/src/*"],
      "@pengawas/api-client": ["packages/api-client/src/index.ts"]
    }
  },
  "include": ["src", "server", "scripts", "vite.config.ts", "tests", "packages/*/src"],
  "exclude": ["dist", "node_modules"]
}
