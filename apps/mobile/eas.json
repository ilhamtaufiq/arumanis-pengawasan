{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_APIAMIS_BASE_URL": "http://apiamis.test/api"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_APIAMIS_BASE_URL": "https://apiamis.cianjur.space/api"
      }
    },
    "production": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_APIAMIS_BASE_URL": "https://apiamis.cianjur.space/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}