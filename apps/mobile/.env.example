# Standalone mobile — langsung ke Laravel API (tanpa BFF pengawas)
# Sama upstream dengan www/bun (APIAMIS_BASE_URL)
#
# Local: http://apiamis.test/api
# Production: https://apiamis.cianjur.space/api
#
# Android emulator ke host Laragon: http://10.0.2.2/api (jika vhost khusus)
# atau IP LAN PC jika device fisik
EXPO_PUBLIC_APIAMIS_BASE_URL=http://apiamis.test/api

# Laravel Reverb (realtime) — samakan dengan apiamis / dashboard web
# Kosongkan EXPO_PUBLIC_REVERB_APP_KEY jika Reverb tidak aktif
EXPO_PUBLIC_REVERB_APP_KEY=
EXPO_PUBLIC_REVERB_HOST=apiamis.test
EXPO_PUBLIC_REVERB_PORT=8080
EXPO_PUBLIC_REVERB_SCHEME=http