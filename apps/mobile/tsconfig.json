{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@/*": ["./*"],
      "@pengawas/shared": ["../../packages/shared/src/index.ts"],
      "@pengawas/shared/*": ["../../packages/shared/src/*"],
      "@pengawas/api-client": ["../../packages/api-client/src/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts", "nativewind-env.d.ts"]
}