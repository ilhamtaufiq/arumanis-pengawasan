{
  "name": "pengawas",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:server": "bun --watch server/index.ts",
    "dev:client": "bunx vite --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "start": "bun run server/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "mobile": "bun run --filter @pengawas/mobile start",
    "mobile:web": "bun run --filter @pengawas/mobile web",
    "mobile:typecheck": "bun run --filter @pengawas/mobile typecheck",
    "mobile:build-android": "bash scripts/build-android.sh",
    "mobile:prebuild": "bun run --filter @pengawas/mobile prebuild"
  },
  "dependencies": {
    "@pengawas/api-client": "workspace:*",
    "@pengawas/shared": "workspace:*",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.59.0",
    "clsx": "^2.1.1",
    "dropzone": "^6.0.0-beta.2",
    "exifr": "^7.1.3",
    "hono": "^4.5.10",
    "laravel-echo": "^2.3.7",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.453.0",
    "pusher-js": "^8.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.80.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.7",
    "remark-gfm": "^4.0.1",
    "tesseract.js": "^7.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.9",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
